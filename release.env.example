# Copy this file to release.env before building the release stack.

PHX_HOST=localhost
DATABASE_URL=ecto://experimenthub:experimenthub_dev@postgres/experiment_hub_dev
SECRET_KEY_BASE=replace-with-mix-phx-gen-secret-at-least-64-bytes-long-before-production-use
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes-before-production-use

REDIS_URL=redis://redis:6379
STAT_ENGINE_URL=http://statistical-engine:8000
STAT_ENGINE_API_KEY=replace-with-the-shared-internal-api-key

KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=experimenthub-event-collector
KAFKA_TOPICS=experimenthub.events.inbound

POOL_SIZE=10
DB_SSL=false
DNS_CLUSTER_QUERY=

# Host port for bundled Postgres only; containers still use postgres:5432.
POSTGRES_PORT=15432

DASHBOARD_PORT=8080
CORS_ORIGINS=http://localhost:8080
DASHBOARD_VITE_API_URL=